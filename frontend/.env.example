# ── Required ──────────────────────────────────────────────────────────────────
# Must match INTERNAL_API_KEY in backend .env
INTERNAL_API_KEY=change-me-strong-random-secret

# Railway backend URL (no trailing slash)
BACKEND_API_URL=https://toc-audit-backend.up.railway.app

# ── Vercel Blob (same token as backend if storing files) ──────────────────────
BLOB_READ_WRITE_TOKEN=vercel_blob_...

# ── Local dev only ────────────────────────────────────────────────────────────
# BACKEND_API_URL=http://localhost:3001
