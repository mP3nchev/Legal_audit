# ── Required ──────────────────────────────────────────────────────────────────
# Must match INTERNAL_API_KEY in backend .env
INTERNAL_API_KEY=change-me-strong-random-secret

# Render backend URL (no trailing slash) — find it in Render dashboard → your service → Settings
BACKEND_API_URL=https://your-service-name.onrender.com

# ── Vercel Blob (same token as backend if storing files) ──────────────────────
BLOB_READ_WRITE_TOKEN=vercel_blob_...

# ── Local dev only ────────────────────────────────────────────────────────────
# BACKEND_API_URL=http://localhost:3001
