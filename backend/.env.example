# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Shared secret — must match INTERNAL_API_KEY in frontend .env
INTERNAL_API_KEY=change-me-strong-random-secret

# ── Database ──────────────────────────────────────────────────────────────────
# Render: add a Persistent Disk (Render dashboard → your service → Disks)
#   Mount path: /data   → then set DATABASE_URL below.
#   WITHOUT a persistent disk, SQLite is wiped on every redeploy/restart!
DATABASE_URL=/data/toc_audit.db
# Local dev: leave unset or override:
# DATABASE_URL=./dev.db

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── Claude AI ────────────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=8192

# ── Budget guard ─────────────────────────────────────────────────────────────
DAILY_BUDGET_USD=20

# ── Vercel Blob (file storage) ────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=vercel_blob_...
